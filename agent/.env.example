# Alpaca Paper Trading
ALPACA_API_KEY=your_paper_api_key
ALPACA_API_SECRET=your_paper_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# MongoDB (Docker service name when containerised)
MONGO_URI=mongodb://mongo:27017/trading-agent

# Agent config
POLL_INTERVAL_MINUTES=15
ASSETS=BTC/USD,ETH/USD
MAX_POSITION_USD=500
OUTCOME_RESOLVE_HOURS=4

# Set to 'ollama' to use local fine-tuned model instead of Claude
LLM_PROVIDER=claude
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=trading-llm
